---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Merch — Anubis Grind">
  <section class="placeholder">
    <h2>Merch</h2>
    <p>Coming soon.</p>
  </section>
</Layout>

<style>
  .placeholder {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding-top: 80px;
  }
  h2 { color: var(--accent-gold); margin-bottom: 1rem; }
  p { color: var(--text-muted); font-family: var(--font-sub); letter-spacing: 0.1em; }
</style>
