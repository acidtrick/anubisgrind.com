---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Anubis Grind">

  <!-- ── Hero ─────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-inner">
      <img src="/band-logo2.png" alt="Anubis Grind" class="hero-logo" />
      <p class="tagline">[ Tagline coming soon ]</p>
      <a href="/music" class="cta-btn">Music Coming May 1st</a>
    </div>
  </section>

  <!-- ── About Blurb ──────────────────────────────────────────── -->
  <section class="about-blurb">
    <h2>About the Band</h2>
    <p>[ Band description coming soon ]</p>
  </section>

  <!-- ── Music Teaser ─────────────────────────────────────────── -->
  <section class="music-teaser">
    <h2>Music</h2>
    <p class="release-date">Dropping May 1st on all platforms</p>
    <div class="platforms">
      <span>Spotify</span>
      <span>Apple Music</span>
      <span>SoundCloud</span>
      <span>YouTube</span>
    </div>
  </section>

</Layout>

<style>
  /* ── Hero ───────────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background:
      radial-gradient(ellipse at center, rgba(139, 26, 26, 0.15) 0%, transparent 70%),
      linear-gradient(to bottom, #0a0808 0%, #120c0c 100%);
    padding-top: 80px;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .hero-logo {
    width: min(600px, 90vw);
    height: auto;
    filter: drop-shadow(0 0 40px rgba(139, 26, 26, 0.6));
  }

  .tagline {
    font-family: var(--font-sub);
    font-size: clamp(1rem, 2.5vw, 1.4rem);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--accent-gold);
    opacity: 0.85;
  }

  .cta-btn {
    display: inline-block;
    font-family: var(--font-sub);
    font-size: 0.85rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text);
    border: 1px solid var(--accent-red);
    padding: 0.85rem 2.5rem;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }

  .cta-btn:hover {
    background: var(--accent-red);
    color: var(--text);
  }

  /* ── About Blurb ────────────────────────────────────────────── */
  .about-blurb {
    border-top: 1px solid rgba(201, 168, 76, 0.15);
  }

  .about-blurb h2 {
    color: var(--accent-gold);
    margin-bottom: 1.5rem;
    font-size: 1rem;
  }

  .about-blurb p {
    color: var(--text-muted);
    max-width: 680px;
    font-size: 1.05rem;
  }

  /* ── Music Teaser ───────────────────────────────────────────── */
  .music-teaser {
    border-top: 1px solid rgba(201, 168, 76, 0.15);
    text-align: center;
  }

  .music-teaser h2 {
    color: var(--accent-gold);
    margin-bottom: 1rem;
    font-size: 1rem;
  }

  .release-date {
    font-family: var(--font-sub);
    font-size: 1.4rem;
    color: var(--text);
    margin-bottom: 2rem;
    letter-spacing: 0.05em;
  }

  .platforms {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.5rem;
  }

  .platforms span {
    font-family: var(--font-sub);
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-muted);
    border: 1px solid rgba(201, 168, 76, 0.2);
    padding: 0.5rem 1.25rem;
  }
</style>
