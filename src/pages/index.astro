---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Anubis Grind">

  <!-- ── Hero ─────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-inner">
      <img src="/band-logo2.png" alt="Anubis Grind" class="hero-logo" />
    </div>
  </section>

</Layout>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background:
      radial-gradient(ellipse at center, rgba(139, 26, 26, 0.15) 0%, transparent 70%),
      linear-gradient(to bottom, #0a0808 0%, #120c0c 100%);
    padding-top: 80px;
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-logo {
    width: min(600px, 90vw);
    height: auto;
    filter: drop-shadow(0 0 40px rgba(139, 26, 26, 0.6));
  }
</style>
